# Server Configuration
PORT=5000
NODE_ENV=development
MOOD=DEV

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/gait-recognition

# Authentication (JWT)
ACCESS_TOKEN_SIGNATURE=your_access_token_signature_key
REFRESH_TOKEN_SIGNATURE=your_refresh_token_signature_key
ACCESS_TOKEN_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=30d

# Email Configuration (Gmail SMTP)
EMAIL=your_email@gmail.com
APP_PASSWORD=your_gmail_app_password
EMAIL_FROM=noreply@gaitrecognition.com

# HuggingFace Configuration
HUGGINGFACE_API_KEY=your_hf_api_token_here
HF_SPACE_URL=https://mohamed6262-gait-1.hf.space/predict
ENABLE_AI_MOCK=false

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Security & Encryption
SALT=10
ENCRYPTION_KEY=your_encryption_key_string

# Rate Limiting
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX=100

# OTP Configuration
OTP_EXPIRY=5
OTP_LENGTH=6

# External AI API (Gait Recognition AI Service)
AI_API_URL=http://localhost:5000/api/analyze

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Google OAuth Configuration
CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# File Upload Configuration
UPLOAD_PATH=uploads
MAX_FILE_SIZE=5242880
