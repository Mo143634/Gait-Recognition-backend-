# Server Configuration
PORT=5000
MOOD=DEV

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/gait-recognition

# JWT Tokens
ACCESS_TOKEN_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=30d

# JWT Signatures
ACCESS_USER_SIGNATURE_TOKEN=your_access_user_signature_token
REFRESH_USER_SIGNATURE_TOKEN=your_refresh_user_signature_token
ACCESS_ADMIN_SIGNATURE_TOKEN=your_access_admin_signature_token
REFRESH_ADMIN_SIGNATURE_TOKEN=your_refresh_admin_signature_token

# Cloudinary Configuration
CLOUD_NAME=your_cloudinary_cloud_name
API_KEY=your_cloudinary_api_key
API_SECRET=your_cloudinary_api_secret

# Email Configuration (Nodemailer - GMail App Password recommended)
EMAIL=your_email@gmail.com
APP_PASSWORD=your_gmail_app_password
EMAIL_FROM=noreply@gaitrecognition.com

# Rate Limiting
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX=100

# External AI API (Gait Recognition AI Service)
AI_API_URL=http://localhost:5000/api/analyze

# CORS Origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://yourdomain.com

# Delete Unactivated Users Cron Job (in hours)
DELETE_UNACTIVATED_USERS_INTERVAL=24
